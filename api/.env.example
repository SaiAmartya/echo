# Echo API env

# --- Gemini (swarm + analysis + report) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_ANALYSIS_MODEL=gemini-3-flash-preview
MAX_LLM_CALLS_PER_SIMULATION=40
MAX_CONCURRENT_LLM_CALLS=6
MAX_TOKENS_PER_CALL=256

# --- Firebase Admin (token verification) ---
# Either point at a service-account JSON file...
GOOGLE_APPLICATION_CREDENTIALS=
# ...or inline the JSON string:
FIREBASE_SERVICE_ACCOUNT_JSON=
# Dev-only escape hatch — never set in prod. Bypasses verification, every
# request is treated as uid="dev-local".
# FIREBASE_AUTH_DISABLED=1

# --- DB ---
# Optional override for SQLite path (default: api/echo.db)
ECHO_DB_PATH=
