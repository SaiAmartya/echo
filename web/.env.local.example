# Echo frontend env
# Backend base URL (proxied via /api/* in next.config.mjs)
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# --- Local-dev auth bypass ---
# Set to "1" to skip Firebase entirely on the FE — AuthProvider will treat the
# session as signed-in as a dev user. Mirrors the api's FIREBASE_AUTH_DISABLED=1
# (which makes the backend accept any token). Use ONLY for local dev — never
# in a production build.
NEXT_PUBLIC_DISABLE_AUTH=

# --- Firebase Auth (web client config) ---
# These are PUBLIC values from the Firebase console (Project settings → Your apps).
# Safe to commit because security comes from Firebase Auth rules, not these keys.
# Leave blank when NEXT_PUBLIC_DISABLE_AUTH=1.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
