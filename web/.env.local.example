# Echo frontend env
# Backend base URL (proxied via /api/* in next.config.mjs)
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# --- Clerk auth (Step 1: scaffolded but optional). Leave empty to disable. ---
# Get keys at https://dashboard.clerk.com/. Frontend uses the publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
